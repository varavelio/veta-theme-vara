{% set site_title = site_setting("title") %}
{% set site_description = site_setting("description") %}
{% set site_favicon = site_setting("favicon") %}

<!DOCTYPE html>
<html lang='{{ page.lang | default:"en" }}'>
  <head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">

    {% block title %}
      {% if page.title and page.title != site_title %}
        <title>{{ page.title }} - {{ site_title }}</title>
      {% else %}
        <title>{{ site_title }}</title>
      {% endif %}
    {% endblock %}

    {% block seo %}
      {% set description = page.description | default:site_description %}
      {% if description %}
        <meta name="description" content="{{ description }}">
      {% endif %}
      {% if page.keywords %}
        <meta name="keywords" content="{{ page.keywords }}">
      {% endif %}
      {% if page.title %}
        <meta property="og:title" content="{{ page.title }}">
      {% endif %}
      {% if description %}
        <meta property="og:description" content="{{ description }}">
      {% endif %}
      {% if page.permalink %}
        <link rel="canonical" href="{{ page.permalink }}">
      {% endif %}
      <meta property="og:type" content='{{ page.og_type | default:"website" }}'>
    {% endblock %}

    {% block favicon %}
      {% if site_favicon %}
        <link rel="shortcut icon" href="{{ site_favicon }}">
      {% endif %}
    {% endblock %}

    <link rel="stylesheet" href="{{ url('/styles.css') }}">
    <script src="{{ url('/_vara/js/build/head.js') }}"></script>

    {% block head_extra %}
    {% endblock %}
  </head>
  <body class="w-dvw h-dvh overflow-hidden bg-base-100 text-content">
    {% block body %}
    {% endblock %}
  </body>
</html>
