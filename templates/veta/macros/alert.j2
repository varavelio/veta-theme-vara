{% comment %}
  Static alert banner for conveying status information.

  Parameters:
    title       - Alert title text
    description - Alert description text
    color       - "neutral" (default) | "info" | "success" | "warning" | "error"
    icon_name   - Override the default icon name
    class       - Additional CSS classes
{% endcomment %}

{% macro alert(title="", description="", color="neutral", icon_name="", class="") export %}
  {% set base_classes = "relative rounded-lg border p-4" %}

  {# Color variants #}
  {% if color == "info" %}
    {% set color_classes = "border-info/40 bg-info/2 text-info" %}
    {% set default_icon = "info" %}
  {% elif color == "success" %}
    {% set color_classes = "border-success/40 bg-success/2 text-success" %}
    {% set default_icon = "circle-check" %}
  {% elif color == "warning" %}
    {% set color_classes = "border-warning/40 bg-warning/2 text-warning" %}
    {% set default_icon = "triangle-alert" %}
  {% elif color == "error" %}
    {% set color_classes = "border-error/40 bg-error/2 text-error" %}
    {% set default_icon = "circle-x" %}
  {% else %}
    {% set color_classes = "border-base-400 bg-base-200/2 text-content" %}
    {% set default_icon = "info" %}
  {% endif %}

  {% if icon_name %}
    {% set resolved_icon = icon_name %}
  {% else %}
    {% set resolved_icon = default_icon %}
  {% endif %}

  {% set all_classes = base_classes + " " + color_classes %}
  {% if class %}
    {% set all_classes = all_classes + " " + class %}
  {% endif %}

  {% if color == "error" or color == "warning" %}
    {% set role = "alert" %}
  {% else %}
    {% set role = "status" %}
  {% endif %}

  <div class="{{ all_classes }}" role="{{ role }}">
    <div class="flex gap-3">
      {% if title %}
        <div class="mt-0.5 shrink-0">
          {{ icon(resolved_icon, "size-5") | safe }}
        </div>
      {% endif %}
      <div class="flex-1">
        {% if title %}
          <h3 class="font-medium">
            {{ title }}
          </h3>
        {% endif %}
        {% if description %}
          <p class="text-sm leading-relaxed opacity-90">
            {{ description }}
          </p>
        {% endif %}
      </div>
    </div>
  </div>
{% endmacro %}
