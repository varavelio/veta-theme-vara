{% comment %}
  Compact status indicator or label with variant and color support.

  Parameters:
    text    - Badge content (required)
    size    - "sm" | "md" (default) | "lg"
    variant - "soft" (default) | "solid" | "outline"
    color   - "neutral" (default) | "info" | "success" | "warning" | "error"
    class   - Additional CSS classes
{% endcomment %}

{% macro badge(text, size="md", variant="soft", color="neutral", class="") export %}
  {% set base_classes = "inline-flex items-center justify-center rounded-full border font-medium whitespace-nowrap" %}

  {# Size #}
  {% if size == "sm" %}
    {% set size_classes = "h-5 px-2 text-[11px]" %}
  {% elif size == "lg" %}
    {% set size_classes = "h-7 px-3 text-sm" %}
  {% else %}
    {% set size_classes = "h-6 px-2.5 text-xs" %}
  {% endif %}

  {# Variant + Color #}
  {% if variant == "solid" %}
    {% if color == "info" %}
      {% set color_classes = "border-info bg-info text-white" %}
    {% elif color == "success" %}
      {% set color_classes = "border-success bg-success text-white" %}
    {% elif color == "warning" %}
      {% set color_classes = "border-warning bg-warning text-white" %}
    {% elif color == "error" %}
      {% set color_classes = "border-error bg-error text-white" %}
    {% else %}
      {% set color_classes = "border-content bg-content text-base-100" %}
    {% endif %}
  {% elif variant == "outline" %}
    {% if color == "info" %}
      {% set color_classes = "border-info/30 bg-transparent text-info" %}
    {% elif color == "success" %}
      {% set color_classes = "border-success/30 bg-transparent text-success" %}
    {% elif color == "warning" %}
      {% set color_classes = "border-warning/30 bg-transparent text-warning" %}
    {% elif color == "error" %}
      {% set color_classes = "border-error/30 bg-transparent text-error" %}
    {% else %}
      {% set color_classes = "border-base-400 bg-transparent text-content-muted" %}
    {% endif %}
  {% else %}
    {% if color == "info" %}
      {% set color_classes = "border-info/15 bg-info/10 text-info" %}
    {% elif color == "success" %}
      {% set color_classes = "border-success/15 bg-success/10 text-success" %}
    {% elif color == "warning" %}
      {% set color_classes = "border-warning/15 bg-warning/10 text-warning" %}
    {% elif color == "error" %}
      {% set color_classes = "border-error/15 bg-error/10 text-error" %}
    {% else %}
      {% set color_classes = "border-base-400 bg-base-200 text-content-muted" %}
    {% endif %}
  {% endif %}

  {% set all_classes = base_classes + " " + size_classes + " " + color_classes %}
  {% if class %}
    {% set all_classes = all_classes + " " + class %}
  {% endif %}

  <span class="{{ all_classes }}">{{ text }}</span>
{% endmacro %}
