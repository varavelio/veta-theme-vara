{% set eyebrow = props.eyebrow %}
{% set title = props.title %}
{% set description = props.description %}
{% set q_1 = props.q_1 %}
{% set a_1 = props.a_1 %}
{% set q_2 = props.q_2 %}
{% set a_2 = props.a_2 %}
{% set q_3 = props.q_3 %}
{% set a_3 = props.a_3 %}
{% set q_4 = props.q_4 %}
{% set a_4 = props.a_4 %}
{% set q_5 = props.q_5 %}
