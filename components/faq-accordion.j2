{% set q_10 = props.q_10 %}
{% set a_10 = props.a_10 %}
{% set bg = props.bg %}
{% set class = props.class %}

{% set container = container|default:"lg" %}
{% if container == "xs" %}
  {% set container_cls = "max-w-md" %}
{% elif container == "sm" %}
  {% set container_cls = "max-w-3xl" %}
{% elif container == "md" %}
  {% set container_cls = "max-w-6xl" %}
{% elif container == "xl" %}
  {% set container_cls = "max-w-[120rem]" %}
{% elif container == "full" %}
  {% set container_cls = "max-w-full" %}
{% else %}
  {% set container_cls = "max-w-7xl" %}
{% endif %}

{% set bg = bg|default:"base-100" %}

<section class="bg-{{ bg }} py-10 desk:py-20{% if class %} {{ class }}{% endif %}">
  <div class="mx-auto w-full {{ container_cls }} px-4">
    <div class="mx-auto max-w-4xl space-y-8 desk:space-y-10">
      {% if eyebrow or title or description %}
        <div class="mx-auto flex max-w-3xl flex-col gap-3 text-center">
          {% if eyebrow %}
            <p class="text-xs font-medium uppercase tracking-[0.24em] text-content-muted">
              {{ eyebrow }}
            </p>
          {% endif %}
          {% if title %}
            <h2 class="text-3xl font-semibold tracking-tight text-content desk:text-4xl">
              {{ title }}
            </h2>
          {% endif %}
          {% if description %}
            <p class="text-base leading-7 text-content-muted desk:text-lg">
              {{ description }}
            </p>
          {% endif %}
        </div>
      {% endif %}

      <div
        class="w-full overflow-hidden rounded-lg border border-base-400 bg-base-200 p-4 desk:p-6"
        x-data="{ open: 0 }"
      >
        {% if q_1 %}
          <div class="border-b border-base-400 last:border-b-0">
            <button
              class="flex w-full cursor-pointer items-center justify-between gap-4 py-4 text-left font-medium text-content focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-content"
              x-on:click="open === 0 ? open = null : open = 0"
              x-bind:aria-expanded="open === 0"
            >
              <span>
                {{ q_1 }}
              </span>
              <svg
                class="size-5 shrink-0 text-content-muted transition-transform duration-200"
                x-bind:class="open === 0 ? 'rotate-180' : ''"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
              >
                <path d="m6 9 6 6 6-6" />
              </svg>
            </button>
            <div x-show="open === 0">
              <div class="pb-4 text-sm leading-7 text-content-muted desk:text-base">
                {{ a_1 }}
              </div>
            </div>
          </div>
        {% endif %}
        {% if q_2 %}
