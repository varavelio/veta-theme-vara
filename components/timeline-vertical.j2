{% set container = props.container |default:"lg" %}
{% set eyebrow = props.eyebrow %}
{% set title = props.title %}
{% set description = props.description %}
{% set item_1_date = props.item_1_date %}
{% set item_1_title = props.item_1_title %}
{% set item_1_desc = props.item_1_desc %}
{% set item_1_icon = props.item_1_icon %}
{% set item_2_date = props.item_2_date %}
{% set item_2_title = props.item_2_title %}
{% set item_2_desc = props.item_2_desc %}
{% set item_2_icon = props.item_2_icon %}
{% set item_3_date = props.item_3_date %}
{% set item_3_title = props.item_3_title %}
{% set item_3_desc = props.item_3_desc %}
{% set item_3_icon = props.item_3_icon %}
{% set item_4_date = props.item_4_date %}
{% set item_4_title = props.item_4_title %}
{% set item_4_desc = props.item_4_desc %}
{% set item_4_icon = props.item_4_icon %}
{% set item_5_date = props.item_5_date %}
{% set item_5_title = props.item_5_title %}
{% set item_5_desc = props.item_5_desc %}
{% set item_5_icon = props.item_5_icon %}
{% set bg = props.bg |default:"base-100" %}
{% set class = props.class %}

{% if container == "xs" %}
  {% set container_cls = "max-w-md" %}
{% elif container == "sm" %}
  {% set container_cls = "max-w-3xl" %}
{% elif container == "md" %}
  {% set container_cls = "max-w-6xl" %}
{% elif container == "xl" %}
  {% set container_cls = "max-w-[120rem]" %}
{% elif container == "full" %}
  {% set container_cls = "max-w-full" %}
{% else %}
  {% set container_cls = "max-w-7xl" %}
{% endif %}

<section class="bg-{{ bg }} py-10 desk:py-20{% if class %} {{ class }}{% endif %}">
  <div class="mx-auto w-full {{ container_cls }} px-4">
    <div class="grid gap-8 desk:grid-cols-[0.8fr_1.2fr] desk:gap-10">
      {% if eyebrow or title or description %}
        <div class="flex max-w-3xl flex-col gap-3 text-left">
          {% if eyebrow %}
            <p class="text-xs font-medium uppercase tracking-[0.24em] text-content-muted">{{ eyebrow }}</p>
          {% endif %}
          {% if title %}
            <h2 class="text-3xl font-semibold tracking-tight text-content desk:text-4xl">{{ title }}</h2>
          {% endif %}
          {% if description %}
            <p class="text-base leading-7 text-content-muted desk:text-lg">{{ description }}</p>
          {% endif %}
        </div>
      {% endif %}
      <div class="rounded-lg border border-base-400 bg-base-200 p-4 desk:p-6">
        <div class="space-y-4">
          {% if item_1_title %}
            <div class="grid gap-3 rounded-md border border-base-400 bg-base-100 p-4 desk:grid-cols-[8rem_1fr]">
              <p class="font-mono text-sm text-content-muted">{{ item_1_date }}</p>
              <div class="flex gap-3">
                {% if item_1_icon %}
                  {{ icon(item_1_icon, "mt-1 size-4 shrink-0 text-content")|safe }}
                {% endif %}
                <div>
                  <h3 class="font-medium text-content">{{ item_1_title }}</h3>
                  {% if item_1_desc %}
                    <p class="mt-2 text-sm leading-6 text-content-muted">{{ item_1_desc }}</p>
                  {% endif %}
                </div>
              </div>
            </div>
          {% endif %}
          {% if item_2_title %}
            <div class="grid gap-3 rounded-md border border-base-400 bg-base-100 p-4 desk:grid-cols-[8rem_1fr]">
              <p class="font-mono text-sm text-content-muted">{{ item_2_date }}</p>
              <div class="flex gap-3">
                {% if item_2_icon %}
                  {{ icon(item_2_icon, "mt-1 size-4 shrink-0 text-content")|safe }}
                {% endif %}
                <div>
                  <h3 class="font-medium text-content">{{ item_2_title }}</h3>
                  {% if item_2_desc %}
                    <p class="mt-2 text-sm leading-6 text-content-muted">{{ item_2_desc }}</p>
                  {% endif %}
                </div>
              </div>
            </div>
          {% endif %}
          {% if item_3_title %}
            <div class="grid gap-3 rounded-md border border-base-400 bg-base-100 p-4 desk:grid-cols-[8rem_1fr]">
              <p class="font-mono text-sm text-content-muted">{{ item_3_date }}</p>
              <div class="flex gap-3">
                {% if item_3_icon %}
                  {{ icon(item_3_icon, "mt-1 size-4 shrink-0 text-content")|safe }}
                {% endif %}
                <div>
                  <h3 class="font-medium text-content">{{ item_3_title }}</h3>
                  {% if item_3_desc %}
                    <p class="mt-2 text-sm leading-6 text-content-muted">{{ item_3_desc }}</p>
                  {% endif %}
                </div>
              </div>
            </div>
          {% endif %}
          {% if item_4_title %}
            <div class="grid gap-3 rounded-md border border-base-400 bg-base-100 p-4 desk:grid-cols-[8rem_1fr]">
              <p class="font-mono text-sm text-content-muted">{{ item_4_date }}</p>
              <div class="flex gap-3">
                {% if item_4_icon %}
                  {{ icon(item_4_icon, "mt-1 size-4 shrink-0 text-content")|safe }}
                {% endif %}
                <div>
                  <h3 class="font-medium text-content">{{ item_4_title }}</h3>
                  {% if item_4_desc %}
                    <p class="mt-2 text-sm leading-6 text-content-muted">{{ item_4_desc }}</p>
                  {% endif %}
                </div>
              </div>
            </div>
          {% endif %}
          {% if item_5_title %}
            <div class="grid gap-3 rounded-md border border-base-400 bg-base-100 p-4 desk:grid-cols-[8rem_1fr]">
              <p class="font-mono text-sm text-content-muted">{{ item_5_date }}</p>
              <div class="flex gap-3">
                {% if item_5_icon %}
                  {{ icon(item_5_icon, "mt-1 size-4 shrink-0 text-content")|safe }}
                {% endif %}
                <div>
                  <h3 class="font-medium text-content">{{ item_5_title }}</h3>
                  {% if item_5_desc %}
                    <p class="mt-2 text-sm leading-6 text-content-muted">{{ item_5_desc }}</p>
                  {% endif %}
                </div>
              </div>
            </div>
          {% endif %}
        </div>
      </div>
    </div>
  </div>
</section>
