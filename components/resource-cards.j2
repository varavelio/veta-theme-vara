{% set container = props.container |default:"lg" %}
{% set eyebrow = props.eyebrow %}
{% set title = props.title %}
{% set description = props.description %}
{% set item_1_type = props.item_1_type %}
{% set item_1_title = props.item_1_title %}
{% set item_1_desc = props.item_1_desc %}
{% set item_1_href = props.item_1_href %}
{% set item_1_meta = props.item_1_meta %}
{% set item_2_type = props.item_2_type %}
{% set item_2_title = props.item_2_title %}
{% set item_2_desc = props.item_2_desc %}
{% set item_2_href = props.item_2_href %}
{% set item_2_meta = props.item_2_meta %}
{% set item_3_type = props.item_3_type %}
{% set item_3_title = props.item_3_title %}
{% set item_3_desc = props.item_3_desc %}
{% set item_3_href = props.item_3_href %}
{% set item_3_meta = props.item_3_meta %}
{% set item_4_type = props.item_4_type %}
{% set item_4_title = props.item_4_title %}
{% set item_4_desc = props.item_4_desc %}
{% set item_4_href = props.item_4_href %}
{% set item_4_meta = props.item_4_meta %}
{% set bg = props.bg |default:"base-100" %}
{% set class = props.class %}

{% if container == "xs" %}
  {% set container_cls = "max-w-md" %}
{% elif container == "sm" %}
  {% set container_cls = "max-w-3xl" %}
{% elif container == "md" %}
  {% set container_cls = "max-w-6xl" %}
{% elif container == "xl" %}
  {% set container_cls = "max-w-[120rem]" %}
{% elif container == "full" %}
  {% set container_cls = "max-w-full" %}
{% else %}
  {% set container_cls = "max-w-7xl" %}
{% endif %}

<section class="bg-{{ bg }} py-10 desk:py-20{% if class %} {{ class }}{% endif %}">
  <div class="mx-auto w-full {{ container_cls }} px-4">
    <div class="space-y-8 desk:space-y-10">
      {% if eyebrow or title or description %}
        <div class="mx-auto flex max-w-3xl flex-col gap-3 text-center">
          {% if eyebrow %}
            <p class="text-xs font-medium uppercase tracking-[0.24em] text-content-muted">{{ eyebrow }}</p>
          {% endif %}
          {% if title %}
            <h2 class="text-3xl font-semibold tracking-tight text-content desk:text-4xl">{{ title }}</h2>
          {% endif %}
          {% if description %}
            <p class="text-base leading-7 text-content-muted desk:text-lg">{{ description }}</p>
          {% endif %}
        </div>
      {% endif %}
      <div class="grid gap-4 desk:grid-cols-4 desk:gap-5">
        {% if item_1_title %}
          <a href="{{ item_1_href |default:'#' }}" class="flex h-full flex-col rounded-lg border border-base-400 bg-base-200 p-4 no-underline transition-colors hover:bg-base-300">
            <p class="text-xs font-medium uppercase tracking-[0.24em] text-content-muted">{{ item_1_type }}</p>
            <h3 class="mt-4 font-medium text-content">{{ item_1_title }}</h3>
            {% if item_1_desc %}
              <p class="mt-2 text-sm leading-6 text-content-muted">{{ item_1_desc }}</p>
            {% endif %}
            <span class="mt-auto inline-flex items-center gap-2 pt-5 text-sm font-medium text-content">
              {{ item_1_meta |default:"Read more" }}
              {{ icon("arrow-right", "size-4")|safe }}
            </span>
          </a>
        {% endif %}
        {% if item_2_title %}
          <a href="{{ item_2_href |default:'#' }}" class="flex h-full flex-col rounded-lg border border-base-400 bg-base-200 p-4 no-underline transition-colors hover:bg-base-300">
            <p class="text-xs font-medium uppercase tracking-[0.24em] text-content-muted">{{ item_2_type }}</p>
            <h3 class="mt-4 font-medium text-content">{{ item_2_title }}</h3>
            {% if item_2_desc %}
              <p class="mt-2 text-sm leading-6 text-content-muted">{{ item_2_desc }}</p>
            {% endif %}
            <span class="mt-auto inline-flex items-center gap-2 pt-5 text-sm font-medium text-content">
              {{ item_2_meta |default:"Read more" }}
              {{ icon("arrow-right", "size-4")|safe }}
            </span>
          </a>
        {% endif %}
        {% if item_3_title %}
          <a href="{{ item_3_href |default:'#' }}" class="flex h-full flex-col rounded-lg border border-base-400 bg-base-200 p-4 no-underline transition-colors hover:bg-base-300">
            <p class="text-xs font-medium uppercase tracking-[0.24em] text-content-muted">{{ item_3_type }}</p>
            <h3 class="mt-4 font-medium text-content">{{ item_3_title }}</h3>
            {% if item_3_desc %}
              <p class="mt-2 text-sm leading-6 text-content-muted">{{ item_3_desc }}</p>
            {% endif %}
            <span class="mt-auto inline-flex items-center gap-2 pt-5 text-sm font-medium text-content">
              {{ item_3_meta |default:"Read more" }}
              {{ icon("arrow-right", "size-4")|safe }}
            </span>
          </a>
        {% endif %}
        {% if item_4_title %}
          <a href="{{ item_4_href |default:'#' }}" class="flex h-full flex-col rounded-lg border border-base-400 bg-base-200 p-4 no-underline transition-colors hover:bg-base-300">
            <p class="text-xs font-medium uppercase tracking-[0.24em] text-content-muted">{{ item_4_type }}</p>
            <h3 class="mt-4 font-medium text-content">{{ item_4_title }}</h3>
            {% if item_4_desc %}
              <p class="mt-2 text-sm leading-6 text-content-muted">{{ item_4_desc }}</p>
            {% endif %}
            <span class="mt-auto inline-flex items-center gap-2 pt-5 text-sm font-medium text-content">
              {{ item_4_meta |default:"Read more" }}
              {{ icon("arrow-right", "size-4")|safe }}
            </span>
          </a>
        {% endif %}
      </div>
    </div>
  </div>
</section>
