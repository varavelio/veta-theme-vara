{% set container = props.container|default:"lg" %}
{% set bg = props.bg|default:"base-100" %}

{% if container == "xs" %}
  {% set container_cls = "max-w-md" %}
{% elif container == "sm" %}
  {% set container_cls = "max-w-3xl" %}
{% elif container == "md" %}
  {% set container_cls = "max-w-6xl" %}
{% elif container == "xl" %}
  {% set container_cls = "max-w-[120rem]" %}
{% elif container == "full" %}
  {% set container_cls = "max-w-full" %}
{% else %}
  {% set container_cls = "max-w-7xl" %}
{% endif %}

<section class="bg-{{ bg }} py-10 desk:py-20{% if props.class %} {{ props.class }}{% endif %}">
  <div class="mx-auto w-full {{ container_cls }} px-4">
    <div class="space-y-8 desk:space-y-10">
      {% if props.eyebrow or props.title or props.description %}
        <div class="mx-auto flex max-w-3xl flex-col gap-3 text-center">
          {% if props.eyebrow %}
            <p class="text-xs font-medium uppercase tracking-[0.24em] text-content-muted">
              {{ props.eyebrow }}
            </p>
          {% endif %}
          {% if props.title %}
            <h2 class="text-3xl font-semibold tracking-tight text-content desk:text-4xl">
              {{ props.title }}
            </h2>
          {% endif %}
          {% if props.description %}
            <p class="text-base leading-7 text-content-muted desk:text-lg">
              {{ props.description }}
            </p>
          {% endif %}
        </div>
      {% endif %}

      <div class="grid gap-4 desk:grid-cols-3 desk:gap-5">
        {% if props.card_1_title %}
          <div class="rounded-lg border border-base-400 bg-base-200 p-4 desk:p-6">
            <div class="flex items-start justify-between gap-4">
              {% if props.card_1_label %}
                <p class="text-xs font-medium uppercase tracking-[0.24em] text-content-muted">
                  {{ props.card_1_label }}
                </p>
              {% endif %}
              {% if props.card_1_icon %}
                <div class="flex size-10 shrink-0 items-center justify-center rounded-md border border-base-400 bg-base-100">
                  {{ icon(props.card_1_icon, "size-5 text-content")|safe }}
                </div>
              {% endif %}
            </div>
            <h3 class="mt-5 text-xl font-medium tracking-tight text-content">
              {{ props.card_1_title }}
            </h3>
            {% if props.card_1_desc %}
              <p class="mt-3 text-sm leading-6 text-content-muted">
                {{ props.card_1_desc }}
              </p>
            {% endif %}
            <div class="mt-5 space-y-3 border-t border-base-400 pt-5">
              {% if props.card_1_point_1 %}
                <p class="flex gap-3 text-sm text-content-muted">
                  {{ icon("check", "size-4 shrink-0 text-content")|safe }}
                  <span>{{ props.card_1_point_1 }}</span>
                </p>
              {% endif %}
              {% if props.card_1_point_2 %}
                <p class="flex gap-3 text-sm text-content-muted">
                  {{ icon("check", "size-4 shrink-0 text-content")|safe }}
                  <span>{{ props.card_1_point_2 }}</span>
                </p>
              {% endif %}
              {% if props.card_1_point_3 %}
                <p class="flex gap-3 text-sm text-content-muted">
                  {{ icon("check", "size-4 shrink-0 text-content")|safe }}
                  <span>{{ props.card_1_point_3 }}</span>
                </p>
              {% endif %}
              {% if props.card_1_point_4 %}
                <p class="flex gap-3 text-sm text-content-muted">
                  {{ icon("check", "size-4 shrink-0 text-content")|safe }}
                  <span>{{ props.card_1_point_4 }}</span>
                </p>
              {% endif %}
            </div>
          </div>
        {% endif %}
        {% if props.card_2_title %}
          <div class="rounded-lg border border-base-400 bg-base-200 p-4 desk:p-6">
            <div class="flex items-start justify-between gap-4">
              {% if props.card_2_label %}
                <p class="text-xs font-medium uppercase tracking-[0.24em] text-content-muted">
                  {{ props.card_2_label }}
                </p>
              {% endif %}
              {% if props.card_2_icon %}
                <div class="flex size-10 shrink-0 items-center justify-center rounded-md border border-base-400 bg-base-100">
                  {{ icon(props.card_2_icon, "size-5 text-content")|safe }}
                </div>
              {% endif %}
            </div>
            <h3 class="mt-5 text-xl font-medium tracking-tight text-content">
              {{ props.card_2_title }}
            </h3>
            {% if props.card_2_desc %}
              <p class="mt-3 text-sm leading-6 text-content-muted">
                {{ props.card_2_desc }}
              </p>
            {% endif %}
            <div class="mt-5 space-y-3 border-t border-base-400 pt-5">
              {% if props.card_2_point_1 %}
                <p class="flex gap-3 text-sm text-content-muted">
                  {{ icon("check", "size-4 shrink-0 text-content")|safe }}
                  <span>{{ props.card_2_point_1 }}</span>
                </p>
              {% endif %}
              {% if props.card_2_point_2 %}
                <p class="flex gap-3 text-sm text-content-muted">
                  {{ icon("check", "size-4 shrink-0 text-content")|safe }}
                  <span>{{ props.card_2_point_2 }}</span>
                </p>
              {% endif %}
              {% if props.card_2_point_3 %}
                <p class="flex gap-3 text-sm text-content-muted">
                  {{ icon("check", "size-4 shrink-0 text-content")|safe }}
                  <span>{{ props.card_2_point_3 }}</span>
                </p>
              {% endif %}
              {% if props.card_2_point_4 %}
                <p class="flex gap-3 text-sm text-content-muted">
                  {{ icon("check", "size-4 shrink-0 text-content")|safe }}
                  <span>{{ props.card_2_point_4 }}</span>
                </p>
              {% endif %}
            </div>
          </div>
        {% endif %}
        {% if props.card_3_title %}
          <div class="rounded-lg border border-base-400 bg-base-200 p-4 desk:p-6">
            <div class="flex items-start justify-between gap-4">
              {% if props.card_3_label %}
                <p class="text-xs font-medium uppercase tracking-[0.24em] text-content-muted">
                  {{ props.card_3_label }}
                </p>
              {% endif %}
              {% if props.card_3_icon %}
                <div class="flex size-10 shrink-0 items-center justify-center rounded-md border border-base-400 bg-base-100">
                  {{ icon(props.card_3_icon, "size-5 text-content")|safe }}
                </div>
              {% endif %}
            </div>
            <h3 class="mt-5 text-xl font-medium tracking-tight text-content">
              {{ props.card_3_title }}
            </h3>
            {% if props.card_3_desc %}
              <p class="mt-3 text-sm leading-6 text-content-muted">
                {{ props.card_3_desc }}
              </p>
            {% endif %}
            <div class="mt-5 space-y-3 border-t border-base-400 pt-5">
              {% if props.card_3_point_1 %}
                <p class="flex gap-3 text-sm text-content-muted">
                  {{ icon("check", "size-4 shrink-0 text-content")|safe }}
                  <span>{{ props.card_3_point_1 }}</span>
                </p>
              {% endif %}
              {% if props.card_3_point_2 %}
                <p class="flex gap-3 text-sm text-content-muted">
                  {{ icon("check", "size-4 shrink-0 text-content")|safe }}
                  <span>{{ props.card_3_point_2 }}</span>
                </p>
              {% endif %}
              {% if props.card_3_point_3 %}
                <p class="flex gap-3 text-sm text-content-muted">
                  {{ icon("check", "size-4 shrink-0 text-content")|safe }}
                  <span>{{ props.card_3_point_3 }}</span>
                </p>
              {% endif %}
              {% if props.card_3_point_4 %}
                <p class="flex gap-3 text-sm text-content-muted">
                  {{ icon("check", "size-4 shrink-0 text-content")|safe }}
                  <span>{{ props.card_3_point_4 }}</span>
                </p>
              {% endif %}
            </div>
          </div>
        {% endif %}
      </div>
    </div>
  </div>
</section>
