{% set text = props.text|default:props.content|default:"" %}
{% set size = props.size|default:"md" %}
{% set base = "inline-flex items-center justify-center rounded-sm border border-b-2 border-base-400 bg-base-200 font-mono font-medium text-content-muted" %}

{% if size == "sm" %}
  {% set size_cls = "h-5 px-1.5 text-[10px]" %}
{% elif size == "lg" %}
  {% set size_cls = "h-7 px-2.5 text-xs" %}
{% else %}
  {% set size_cls = "h-6 px-2 text-[11px]" %}
{% endif %}

{% set all = base + " " + size_cls %}

{% if props.class %}
  {% set all = all + " " + props.class %}
{% endif %}

<kbd class="{{ all }}">{{ text }}</kbd>
