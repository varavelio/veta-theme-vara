{% set container = props.container %}
{% set eyebrow = props.eyebrow %}
{% set title = props.title %}
{% set description = props.description %}
{% set item_1_icon = props.item_1_icon %}
{% set item_1_title = props.item_1_title %}
{% set item_1_desc = props.item_1_desc %}
{% set item_1_meta = props.item_1_meta %}
{% set item_2_icon = props.item_2_icon %}
{% set item_2_title = props.item_2_title %}
{% set item_2_desc = props.item_2_desc %}
{% set item_2_meta = props.item_2_meta %}
{% set item_3_icon = props.item_3_icon %}
{% set item_3_title = props.item_3_title %}
{% set item_3_desc = props.item_3_desc %}
{% set item_3_meta = props.item_3_meta %}
{% set item_4_icon = props.item_4_icon %}
{% set item_4_title = props.item_4_title %}
{% set item_4_desc = props.item_4_desc %}
{% set item_4_meta = props.item_4_meta %}
{% set item_5_icon = props.item_5_icon %}
{% set item_5_title = props.item_5_title %}
{% set item_5_desc = props.item_5_desc %}
{% set item_5_meta = props.item_5_meta %}
{% set bg = props.bg %}
{% set class = props.class %}

{% set container = container|default:"lg" %}
{% if container == "xs" %}
  {% set container_cls = "max-w-md" %}
{% elif container == "sm" %}
  {% set container_cls = "max-w-3xl" %}
{% elif container == "md" %}
  {% set container_cls = "max-w-6xl" %}
{% elif container == "xl" %}
  {% set container_cls = "max-w-[120rem]" %}
{% elif container == "full" %}
  {% set container_cls = "max-w-full" %}
{% else %}
  {% set container_cls = "max-w-7xl" %}
{% endif %}

{% set bg = bg|default:"base-100" %}

<section class="bg-{{ bg }} py-10 desk:py-20{% if class %} {{ class }}{% endif %}">
  <div class="mx-auto w-full {{ container_cls }} px-4">
    <div class="space-y-8 desk:space-y-10">
      {% if eyebrow or title or description %}
        <div class="mx-auto flex max-w-3xl flex-col gap-3 text-center">
          {% if eyebrow %}
            <p class="text-xs font-medium uppercase tracking-[0.24em] text-content-muted">
              {{ eyebrow }}
            </p>
          {% endif %}
          {% if title %}
            <h2 class="text-3xl font-semibold tracking-tight text-content desk:text-4xl">
              {{ title }}
            </h2>
          {% endif %}
          {% if description %}
            <p class="text-base leading-7 text-content-muted desk:text-lg">
              {{ description }}
            </p>
          {% endif %}
        </div>
      {% endif %}
      <div class="grid gap-4 desk:grid-cols-3 desk:auto-rows-fr desk:gap-5">
        {% if item_1_title %}
          <div class="rounded-lg border border-base-400 bg-base-200 p-4 desk:col-span-2 desk:row-span-2 desk:p-6">
            {% if item_1_icon %}
              <div class="flex size-10 items-center justify-center rounded-md border border-base-400 bg-base-100">
                {{ icon(item_1_icon, "size-5 text-content")|safe }}
              </div>
            {% endif %}
            {% if item_1_meta %}
              <p class="mt-5 text-xs font-medium uppercase tracking-[0.24em] text-content-muted">
                {{ item_1_meta }}
              </p>
            {% endif %}
            <h3 class="mt-3 text-2xl font-semibold tracking-tight text-content desk:text-3xl">
              {{ item_1_title }}
            </h3>
            {% if item_1_desc %}
              <p class="mt-4 max-w-2xl text-sm leading-6 text-content-muted desk:text-base">
                {{ item_1_desc }}
              </p>
            {% endif %}
            <div class="mt-6 grid gap-3 desk:grid-cols-2">
              <div class="h-28 rounded-md border border-base-400 bg-base-100"></div>
              <div class="h-28 rounded-md border border-base-400 bg-base-100"></div>
            </div>
          </div>
        {% endif %}
        {% if item_2_title %}
          <div class="rounded-lg border border-base-400 bg-base-200 p-4 desk:p-6">
            {% if item_2_icon %}
              <div class="flex size-10 items-center justify-center rounded-md border border-base-400 bg-base-100">
                {{ icon(item_2_icon, "size-5 text-content")|safe }}
              </div>
            {% endif %}
            {% if item_2_meta %}
              <p class="mt-5 text-xs font-medium uppercase tracking-[0.24em] text-content-muted">
                {{ item_2_meta }}
              </p>
            {% endif %}
            <h3 class="mt-3 text-xl font-medium tracking-tight text-content">
              {{ item_2_title }}
            </h3>
            {% if item_2_desc %}
              <p class="mt-3 text-sm leading-6 text-content-muted">
                {{ item_2_desc }}
              </p>
            {% endif %}
          </div>
        {% endif %}
        {% if item_3_title %}
          <div class="rounded-lg border border-base-400 bg-base-200 p-4 desk:p-6">
            {% if item_3_icon %}
              <div class="flex size-10 items-center justify-center rounded-md border border-base-400 bg-base-100">
                {{ icon(item_3_icon, "size-5 text-content")|safe }}
              </div>
            {% endif %}
            {% if item_3_meta %}
              <p class="mt-5 text-xs font-medium uppercase tracking-[0.24em] text-content-muted">
                {{ item_3_meta }}
              </p>
            {% endif %}
            <h3 class="mt-3 text-xl font-medium tracking-tight text-content">
              {{ item_3_title }}
            </h3>
            {% if item_3_desc %}
              <p class="mt-3 text-sm leading-6 text-content-muted">
                {{ item_3_desc }}
              </p>
            {% endif %}
          </div>
        {% endif %}
        {% if item_4_title %}
          <div class="rounded-lg border border-base-400 bg-base-200 p-4 desk:p-6">
            {% if item_4_icon %}
              <div class="flex size-10 items-center justify-center rounded-md border border-base-400 bg-base-100">
                {{ icon(item_4_icon, "size-5 text-content")|safe }}
              </div>
            {% endif %}
            {% if item_4_meta %}
              <p class="mt-5 text-xs font-medium uppercase tracking-[0.24em] text-content-muted">
                {{ item_4_meta }}
              </p>
            {% endif %}
            <h3 class="mt-3 text-xl font-medium tracking-tight text-content">
              {{ item_4_title }}
            </h3>
            {% if item_4_desc %}
              <p class="mt-3 text-sm leading-6 text-content-muted">
                {{ item_4_desc }}
              </p>
            {% endif %}
          </div>
        {% endif %}
        {% if item_5_title %}
          <div class="rounded-lg border border-base-400 bg-base-200 p-4 desk:p-6">
            {% if item_5_icon %}
              <div class="flex size-10 items-center justify-center rounded-md border border-base-400 bg-base-100">
                {{ icon(item_5_icon, "size-5 text-content")|safe }}
              </div>
            {% endif %}
            {% if item_5_meta %}
              <p class="mt-5 text-xs font-medium uppercase tracking-[0.24em] text-content-muted">
                {{ item_5_meta }}
              </p>
            {% endif %}
            <h3 class="mt-3 text-xl font-medium tracking-tight text-content">
              {{ item_5_title }}
            </h3>
            {% if item_5_desc %}
              <p class="mt-3 text-sm leading-6 text-content-muted">
                {{ item_5_desc }}
              </p>
            {% endif %}
          </div>
        {% endif %}
      </div>
    </div>
  </div>
</section>
