{% import "../templates/veta/macros/button.j2" button %}

{% set container = props.container | default:"lg" %}
{% set title = props.title %}
{% set description = props.description %}
{% set announcement = props.announcement %}
{% set announcement_url = props.announcement_url | default:"#" %}
{% set action_1_text = props.action_1_text %}
{% set action_1_url = props.action_1_url | default:"#" %}
{% set action_1_variant = props.action_1_variant | default:"solid" %}
{% set action_1_color = props.action_1_color | default:"neutral" %}
{% set action_2_text = props.action_2_text %}
{% set action_2_url = props.action_2_url | default:"#" %}
{% set action_2_variant = props.action_2_variant | default:"outline" %}
{% set action_2_color = props.action_2_color | default:"neutral" %}
{% set caption = props.caption %}
{% set bg = props.bg | default:"base-100" %}
{% set class = props.class %}

{% if container == "xs" %}
  {% set container_cls = "max-w-md" %}
{% elif container == "sm" %}
  {% set container_cls = "max-w-3xl" %}
{% elif container == "md" %}
  {% set container_cls = "max-w-6xl" %}
{% elif container == "xl" %}
  {% set container_cls = "max-w-[120rem]" %}
{% elif container == "full" %}
  {% set container_cls = "max-w-full" %}
{% else %}
  {% set container_cls = "max-w-7xl" %}
{% endif %}

<section class="bg-{{ bg }} py-12 desk:py-24{% if class %} {{ class }}{% endif %}">
  <div class="mx-auto w-full {{ container_cls }} px-4">
    <div class="mx-auto flex max-w-4xl flex-col items-center text-center">
      {% if announcement %}
        <a
          href="{{ announcement_url }}"
          class="mb-5 inline-flex items-center gap-2 rounded-full border border-base-400 bg-base-100 px-3 py-1.5 text-xs font-medium uppercase tracking-[0.18em] text-content-muted no-underline transition-colors hover:bg-base-200 hover:text-content focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-content"
        >
          {{ announcement }}
          {{ icon("arrow-right", "size-3.5") | safe }}
        </a>
      {% endif %}

      <h1 class="max-w-4xl text-4xl font-semibold tracking-tight text-content desk:text-6xl">
        {{ title | safe }}
      </h1>

      {% if description %}
        <p class="mt-5 max-w-2xl text-base leading-7 text-content-muted desk:text-xl desk:leading-8">
          {{ description | safe }}
        </p>
      {% endif %}

      {% if action_1_text %}
        <div class="mt-8 flex w-full flex-col justify-center gap-3 desk:w-auto desk:flex-row">
          {{ button(action_1_text, action_1_url, "", "", "", "lg", "md", action_1_variant, action_1_color, "true", "false", "button", "desk:w-auto") }}
          {% if action_2_text %}
            {{ button(action_2_text, action_2_url, "", "", "", "lg", "md", action_2_variant, action_2_color, "true", "false", "button", "desk:w-auto") }}
          {% endif %}
        </div>
      {% endif %}

      {% if caption %}
        <p class="mt-4 max-w-xl text-sm leading-6 text-content-muted">
          {{ caption }}
        </p>
      {% endif %}
    </div>
  </div>
</section>
