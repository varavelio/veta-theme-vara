                  {{ icon(item_2_icon, "size-5 text-content")|safe }}
                </div>
              {% endif %}
            </div>
            <div class="space-y-2">
              <h3 class="text-lg font-medium tracking-tight text-content desk:text-xl">{{ item_2_title }}</h3>
              {% if item_2_desc %}
                <p class="text-sm leading-6 text-content-muted">{{ item_2_desc }}</p>
              {% endif %}
            </div>
            {% if item_2_href %}
