              {% endif %}
            </div>
            {% if item_4_href %}
              <a href="{{ item_4_href }}" class="mt-auto inline-flex items-center gap-2 text-sm font-medium text-content no-underline transition-colors hover:text-info">
                {{ item_4_link |default:"Learn more" }}
                {{ icon("arrow-right", "size-4")|safe }}
              </a>
            {% endif %}
          </div>
        {% endif %}
        {% if item_5_title %}
          <div class="flex h-full flex-col gap-4 rounded-lg border border-base-400 bg-base-200 p-4 desk:p-6">
            <div class="flex items-start justify-between gap-4">
              <span class="font-mono text-4xl font-semibold tracking-tighter text-content-muted">{{ item_5_step |default:"05" }}</span>
              {% if item_5_icon %}
                <div class="flex size-10 items-center justify-center rounded-md border border-base-400 bg-base-100">
                  {{ icon(item_5_icon, "size-5 text-content")|safe }}
                </div>
              {% endif %}
            </div>
            <div class="space-y-2">
              <h3 class="text-lg font-medium tracking-tight text-content desk:text-xl">{{ item_5_title }}</h3>
              {% if item_5_desc %}
                <p class="text-sm leading-6 text-content-muted">{{ item_5_desc }}</p>
