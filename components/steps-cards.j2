{% set container = props.container |default:"lg" %}
{% set eyebrow = props.eyebrow %}
{% set title = props.title %}
{% set description = props.description %}
{% set columns = props.columns %}
{% set bg = props.bg |default:"base-100" %}
{% set item_1_step = props.item_1_step %}
{% set item_1_title = props.item_1_title %}
{% set item_1_desc = props.item_1_desc %}
{% set item_1_icon = props.item_1_icon %}
{% set item_1_href = props.item_1_href %}
{% set item_1_link = props.item_1_link %}
{% set item_2_step = props.item_2_step %}
{% set item_2_title = props.item_2_title %}
{% set item_2_desc = props.item_2_desc %}
{% set item_2_icon = props.item_2_icon %}
{% set item_2_href = props.item_2_href %}
{% set item_2_link = props.item_2_link %}
{% set item_3_step = props.item_3_step %}
{% set item_3_title = props.item_3_title %}
{% set item_3_desc = props.item_3_desc %}
{% set item_3_icon = props.item_3_icon %}
{% set item_3_href = props.item_3_href %}
{% set item_3_link = props.item_3_link %}
{% set item_4_step = props.item_4_step %}
{% set item_4_title = props.item_4_title %}
{% set item_4_desc = props.item_4_desc %}
{% set item_4_icon = props.item_4_icon %}
{% set item_4_href = props.item_4_href %}
{% set item_4_link = props.item_4_link %}
{% set item_5_step = props.item_5_step %}
{% set item_5_title = props.item_5_title %}
{% set item_5_desc = props.item_5_desc %}
{% set item_5_icon = props.item_5_icon %}
{% set item_5_href = props.item_5_href %}
{% set item_5_link = props.item_5_link %}
{% set item_6_step = props.item_6_step %}
{% set item_6_title = props.item_6_title %}
{% set item_6_desc = props.item_6_desc %}
{% set item_6_icon = props.item_6_icon %}
{% set item_6_href = props.item_6_href %}
{% set item_6_link = props.item_6_link %}
{% set class = props.class %}

{% if container == "xs" %}
  {% set container_cls = "max-w-md" %}
{% elif container == "sm" %}
  {% set container_cls = "max-w-3xl" %}
{% elif container == "md" %}
  {% set container_cls = "max-w-6xl" %}
{% elif container == "xl" %}
  {% set container_cls = "max-w-[120rem]" %}
{% elif container == "full" %}
  {% set container_cls = "max-w-full" %}
{% else %}
  {% set container_cls = "max-w-7xl" %}
{% endif %}
{% set cols = columns |default:"3" %}

<section class="bg-{{ bg }} py-10 desk:py-20{% if class %} {{ class }}{% endif %}">
  <div class="mx-auto w-full {{ container_cls }} px-4">
    <div class="space-y-8 desk:space-y-10">
      {% if eyebrow or title or description %}
        <div class="mx-auto flex max-w-3xl flex-col gap-3 text-center">
          {% if eyebrow %}
            <p class="text-xs font-medium uppercase tracking-[0.24em] text-content-muted">{{ eyebrow }}</p>
          {% endif %}
          {% if title %}
            <h2 class="text-3xl font-semibold tracking-tight text-content desk:text-4xl">{{ title }}</h2>
          {% endif %}
          {% if description %}
            <p class="text-base leading-7 text-content-muted desk:text-lg">{{ description }}</p>
          {% endif %}
        </div>
      {% endif %}
      <div class="grid grid-cols-1 gap-4 desk:gap-5{% if cols == '2' %} desk:grid-cols-2{% elif cols == '4' %} desk:grid-cols-4{% else %} desk:grid-cols-3{% endif %}">
        {% if item_1_title %}
          <div class="flex h-full flex-col gap-4 rounded-lg border border-base-400 bg-base-200 p-4 desk:p-6">
            <div class="flex items-start justify-between gap-4">
              <span class="font-mono text-4xl font-semibold tracking-tighter text-content-muted">{{ item_1_step |default:"01" }}</span>
              {% if item_1_icon %}
                <div class="flex size-10 items-center justify-center rounded-md border border-base-400 bg-base-100">
                  {{ icon(item_1_icon, "size-5 text-content")|safe }}
                </div>
              {% endif %}
            </div>
            <div class="space-y-2">
              <h3 class="text-lg font-medium tracking-tight text-content desk:text-xl">{{ item_1_title }}</h3>
              {% if item_1_desc %}
                <p class="text-sm leading-6 text-content-muted">{{ item_1_desc }}</p>
              {% endif %}
            </div>
            {% if item_1_href %}
              <a href="{{ item_1_href }}" class="mt-auto inline-flex items-center gap-2 text-sm font-medium text-content no-underline transition-colors hover:text-info">
                {{ item_1_link |default:"Learn more" }}
                {{ icon("arrow-right", "size-4")|safe }}
              </a>
            {% endif %}
          </div>
        {% endif %}
        {% if item_2_title %}
          <div class="flex h-full flex-col gap-4 rounded-lg border border-base-400 bg-base-200 p-4 desk:p-6">
            <div class="flex items-start justify-between gap-4">
              <span class="font-mono text-4xl font-semibold tracking-tighter text-content-muted">{{ item_2_step |default:"02" }}</span>
