                {{ item_2_link |default:"Learn more" }}
                {{ icon("arrow-right", "size-4")|safe }}
              </a>
            {% endif %}
          </div>
        {% endif %}
        {% if item_3_title %}
          <div class="flex h-full flex-col gap-4 rounded-lg border border-base-400 bg-base-200 p-4 desk:p-6">
            <div class="flex items-start justify-between gap-4">
              <span class="font-mono text-4xl font-semibold tracking-tighter text-content-muted">{{ item_3_step |default:"03" }}</span>
