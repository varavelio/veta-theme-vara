                {{ icon("arrow-right", "size-4")|safe }}
              </a>
            {% endif %}
          </div>
        {% endif %}
        {% if item_6_title %}
          <div class="flex h-full flex-col gap-4 rounded-lg border border-base-400 bg-base-200 p-4 desk:p-6">
            <div class="flex items-start justify-between gap-4">
              <span class="font-mono text-4xl font-semibold tracking-tighter text-content-muted">{{ item_6_step |default:"06" }}</span>
              {% if item_6_icon %}
                <div class="flex size-10 items-center justify-center rounded-md border border-base-400 bg-base-100">
                  {{ icon(item_6_icon, "size-5 text-content")|safe }}
