{% import "../templates/veta/macros/button.j2" button %}

{% set container = props.container | default:"lg" %}
{% set eyebrow = props.eyebrow %}
{% set title = props.title %}
{% set description = props.description %}
{% set form_action = props.form_action | default:"" %}
{% set method = props.method | default:"post" %}
{% set show_name = props.show_name | default:"false" %}
{% set name_label = props.name_label | default:"Name" %}
{% set name_placeholder = props.name_placeholder | default:"Your name" %}
{% set email_label = props.email_label | default:"Email" %}
{% set email_placeholder = props.email_placeholder | default:"you@example.com" %}
{% set button_text = props.button_text | default:"Join the list" %}
{% set button_color = props.button_color | default:"neutral" %}
{% set note = props.note %}
{% set success_message = props.success_message | default:"Thanks. We will be in touch soon." %}
{% set bg = props.bg | default:"base-100" %}
{% set class = props.class %}

{% if container == "xs" %}
  {% set container_cls = "max-w-md" %}
{% elif container == "sm" %}
  {% set container_cls = "max-w-3xl" %}
{% elif container == "md" %}
  {% set container_cls = "max-w-6xl" %}
{% elif container == "xl" %}
  {% set container_cls = "max-w-[120rem]" %}
{% elif container == "full" %}
  {% set container_cls = "max-w-full" %}
{% else %}
  {% set container_cls = "max-w-7xl" %}
{% endif %}

<section class="bg-{{ bg }} py-10 desk:py-20{% if class %} {{ class }}{% endif %}">
  <div class="mx-auto w-full {{ container_cls }} px-4">
    <div
      class="grid gap-4 rounded-lg border border-base-400 bg-base-200 p-4 desk:grid-cols-[1fr_0.9fr] desk:items-center desk:gap-8 desk:p-6"
      x-data="{ submitted: false }"
    >
      <div>
        <div class="flex size-10 items-center justify-center rounded-md border border-base-400 bg-base-100">
          {{ icon("mail", "size-5 text-content") | safe }}
        </div>
        {% if eyebrow %}
          <p class="mt-5 text-xs font-medium uppercase tracking-[0.24em] text-content-muted">
            {{ eyebrow }}
          </p>
        {% endif %}
        {% if title %}
          <h2 class="mt-3 text-3xl font-semibold tracking-tight text-content desk:text-4xl">
            {{ title }}
          </h2>
        {% endif %}
        {% if description %}
          <p class="mt-4 text-base leading-7 text-content-muted desk:text-lg">
            {{ description }}
          </p>
        {% endif %}
      </div>

      <form
        {% if form_action %}
          action="{{ form_action }}"
        {% endif %}
        method="{{ method }}"
        class="rounded-md border border-base-400 bg-base-100 p-4"
        {% if not form_action %}
          x-on:submit.prevent="submitted = true"
        {% endif %}
      >
        <div class="grid gap-3">
          {% if show_name == "true" %}
            <label class="grid gap-2 text-sm font-medium text-content">
              {{ name_label }}
              <input
                name="name"
                type="text"
                placeholder="{{ name_placeholder }}"
                class="h-10 rounded-md border border-base-400 bg-base-100 px-3 text-sm text-content outline-content transition-colors placeholder:text-content-muted focus-visible:outline-2 focus-visible:outline-offset-2"
              />
            </label>
          {% endif %}
          <label class="grid gap-2 text-sm font-medium text-content">
            {{ email_label }}
            <input
              name="email"
              type="email"
              required
              placeholder="{{ email_placeholder }}"
              class="h-10 rounded-md border border-base-400 bg-base-100 px-3 text-sm text-content outline-content transition-colors placeholder:text-content-muted focus-visible:outline-2 focus-visible:outline-offset-2"
            />
          </label>
          {{ button(button_text, "", "", "", "", "md", "md", "solid", button_color, "true", "false", "submit") }}
        </div>
        {% if note %}
          <p class="mt-3 text-xs leading-5 text-content-muted">
            {{ note }}
          </p>
        {% endif %}
        <p class="mt-3 text-sm font-medium text-content" x-show="submitted" x-cloak>
          {{ success_message }}
        </p>
      </form>
    </div>
  </div>
</section>
