{% set container = props.container |default:"lg" %}
{% set eyebrow = props.eyebrow %}
{% set title = props.title %}
{% set description = props.description %}
{% set columns = props.columns %}
{% set bg = props.bg |default:"base-100" %}
{% set item_1_quote = props.item_1_quote %}
{% set item_1_name = props.item_1_name %}
{% set item_1_role = props.item_1_role %}
{% set item_1_company = props.item_1_company %}
{% set item_1_avatar = props.item_1_avatar %}
{% set item_1_rating = props.item_1_rating %}
{% set item_2_quote = props.item_2_quote %}
{% set item_2_name = props.item_2_name %}
{% set item_2_role = props.item_2_role %}
{% set item_2_company = props.item_2_company %}
{% set item_2_avatar = props.item_2_avatar %}
{% set item_2_rating = props.item_2_rating %}
{% set item_3_quote = props.item_3_quote %}
{% set item_3_name = props.item_3_name %}
{% set item_3_role = props.item_3_role %}
{% set item_3_company = props.item_3_company %}
{% set item_3_avatar = props.item_3_avatar %}
{% set item_3_rating = props.item_3_rating %}
{% set item_4_quote = props.item_4_quote %}
{% set item_4_name = props.item_4_name %}
{% set item_4_role = props.item_4_role %}
{% set item_4_company = props.item_4_company %}
{% set item_4_avatar = props.item_4_avatar %}
