{% set container = props.container|default:"lg" %}
{% set bg = props.bg|default:"base-100" %}

{% if container == "xs" %}
  {% set container_cls = "max-w-md" %}
{% elif container == "sm" %}
  {% set container_cls = "max-w-3xl" %}
{% elif container == "md" %}
  {% set container_cls = "max-w-6xl" %}
{% elif container == "xl" %}
  {% set container_cls = "max-w-[120rem]" %}
{% elif container == "full" %}
  {% set container_cls = "max-w-full" %}
{% else %}
  {% set container_cls = "max-w-7xl" %}
{% endif %}

<section class="bg-{{ bg }} py-10 desk:py-20{% if props.class %} {{ props.class }}{% endif %}">
  <div class="mx-auto w-full {{ container_cls }} px-4">
    <div class="space-y-8 desk:space-y-10">
      {% if props.eyebrow or props.title or props.description %}
        <div class="mx-auto flex max-w-3xl flex-col gap-3 text-center">
          {% if props.eyebrow %}
            <p class="text-xs font-medium uppercase tracking-[0.24em] text-content-muted">
              {{ props.eyebrow }}
            </p>
          {% endif %}
          {% if props.title %}
            <h2 class="text-3xl font-semibold tracking-tight text-content desk:text-4xl">
              {{ props.title }}
            </h2>
          {% endif %}
          {% if props.description %}
            <p class="text-base leading-7 text-content-muted desk:text-lg">
              {{ props.description }}
            </p>
          {% endif %}
        </div>
      {% endif %}

      <div class="grid gap-4 desk:grid-cols-3 desk:gap-5">
        {% if props.item_1_title %}
          <article class="flex h-full flex-col rounded-lg border border-base-400 bg-base-200 p-4 desk:p-6">
            {% if props.item_1_customer %}
              <p class="text-xs font-medium uppercase tracking-[0.24em] text-content-muted">
                {{ props.item_1_customer }}
              </p>
            {% endif %}
            <h3 class="mt-4 text-xl font-medium tracking-tight text-content">
              {{ props.item_1_title }}
            </h3>
            {% if props.item_1_desc %}
              <p class="mt-3 text-sm leading-6 text-content-muted">
                {{ props.item_1_desc }}
              </p>
            {% endif %}
            {% if props.item_1_result %}
              <p class="mt-5 border-t border-base-400 pt-4 font-mono text-3xl font-semibold text-content">
                {{ props.item_1_result }}
              </p>
            {% endif %}
            {% if props.item_1_href %}
              <a
                href="{{ props.item_1_href }}"
                class="mt-auto inline-flex items-center gap-2 pt-6 text-sm font-medium text-content no-underline hover:text-info"
              >
                {{ props.item_1_link|default:"Read story" }} {{ icon("arrow-right", "size-4")|safe }}
              </a>
            {% endif %}
          </article>
        {% endif %}
        {% if props.item_2_title %}
          <article class="flex h-full flex-col rounded-lg border border-base-400 bg-base-200 p-4 desk:p-6">
            {% if props.item_2_customer %}
              <p class="text-xs font-medium uppercase tracking-[0.24em] text-content-muted">
                {{ props.item_2_customer }}
              </p>
            {% endif %}
            <h3 class="mt-4 text-xl font-medium tracking-tight text-content">
              {{ props.item_2_title }}
            </h3>
            {% if props.item_2_desc %}
              <p class="mt-3 text-sm leading-6 text-content-muted">
                {{ props.item_2_desc }}
              </p>
            {% endif %}
            {% if props.item_2_result %}
              <p class="mt-5 border-t border-base-400 pt-4 font-mono text-3xl font-semibold text-content">
                {{ props.item_2_result }}
              </p>
            {% endif %}
            {% if props.item_2_href %}
              <a
                href="{{ props.item_2_href }}"
                class="mt-auto inline-flex items-center gap-2 pt-6 text-sm font-medium text-content no-underline hover:text-info"
              >
                {{ props.item_2_link|default:"Read story" }} {{ icon("arrow-right", "size-4")|safe }}
              </a>
            {% endif %}
          </article>
        {% endif %}
        {% if props.item_3_title %}
          <article class="flex h-full flex-col rounded-lg border border-base-400 bg-base-200 p-4 desk:p-6">
            {% if props.item_3_customer %}
              <p class="text-xs font-medium uppercase tracking-[0.24em] text-content-muted">
                {{ props.item_3_customer }}
              </p>
            {% endif %}
            <h3 class="mt-4 text-xl font-medium tracking-tight text-content">
              {{ props.item_3_title }}
            </h3>
            {% if props.item_3_desc %}
              <p class="mt-3 text-sm leading-6 text-content-muted">
                {{ props.item_3_desc }}
              </p>
            {% endif %}
            {% if props.item_3_result %}
              <p class="mt-5 border-t border-base-400 pt-4 font-mono text-3xl font-semibold text-content">
                {{ props.item_3_result }}
              </p>
            {% endif %}
            {% if props.item_3_href %}
              <a
                href="{{ props.item_3_href }}"
                class="mt-auto inline-flex items-center gap-2 pt-6 text-sm font-medium text-content no-underline hover:text-info"
              >
                {{ props.item_3_link|default:"Read story" }} {{ icon("arrow-right", "size-4")|safe }}
              </a>
            {% endif %}
          </article>
        {% endif %}
      </div>
    </div>
  </div>
</section>
