{% set container = props.container | default:"lg" %}
{% set eyebrow = props.eyebrow %}
{% set title = props.title %}
{% set description = props.description %}
{% set duration = props.duration | default:"36s" %}
{% set bg = props.bg | default:"base-100" %}
{% set class = props.class %}

{% if container == "xs" %}
  {% set container_cls = "max-w-md" %}
{% elif container == "sm" %}
  {% set container_cls = "max-w-3xl" %}
{% elif container == "md" %}
  {% set container_cls = "max-w-6xl" %}
{% elif container == "xl" %}
  {% set container_cls = "max-w-[120rem]" %}
{% elif container == "full" %}
  {% set container_cls = "max-w-full" %}
{% else %}
  {% set container_cls = "max-w-7xl" %}
{% endif %}

{% macro logo_item(name, src, alt, href) %}
  {% if href %}
    <a
      href="{{ href }}"
      target="_blank"
      rel="noopener noreferrer"
      class="flex h-16 min-w-40 items-center justify-center rounded-md border border-base-400 bg-base-100 px-5 no-underline transition-colors hover:bg-base-300 focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-content"
    >
  {% else %}
    <div class="flex h-16 min-w-40 items-center justify-center rounded-md border border-base-400 bg-base-100 px-5">
  {% endif %}
  {% if src %}
    <img
      src="{{ src }}"
      alt="{{ alt | default:name }}"
      class="max-h-7 w-auto opacity-70 grayscale"
    />
  {% else %}
    <span class="text-sm font-medium uppercase tracking-[0.18em] text-content-muted">
      {{ name }}
    </span>
  {% endif %}
  {% if href %}
    </a>
  {% else %}
    </div>
  {% endif %}
{% endmacro %}

{% macro duplicate_logo(name, src) %}
  <div class="flex h-16 min-w-40 items-center justify-center rounded-md border border-base-400 bg-base-100 px-5">
    {% if src %}
      <img
        src="{{ src }}"
        alt=""
        class="max-h-7 w-auto opacity-70 grayscale"
      />
    {% else %}
      <span class="text-sm font-medium uppercase tracking-[0.18em] text-content-muted">
        {{ name }}
      </span>
    {% endif %}
  </div>
{% endmacro %}

<style>
  @keyframes varapress-logo-cloud-marquee {
    from {
      transform: translateX(0);
    }

    to {
      transform: translateX(-50%);
    }
  }

  .varapress-logo-cloud-marquee-track {
    animation: varapress-logo-cloud-marquee var(--varapress-logo-cloud-marquee-duration, 36s) linear infinite;
  }

  .varapress-logo-cloud-marquee:hover .varapress-logo-cloud-marquee-track {
    animation-play-state: paused;
  }

  @media (prefers-reduced-motion: reduce) {
    .varapress-logo-cloud-marquee-track {
      animation: none;
      transform: translateX(0);
    }
  }
</style>

<section class="bg-{{ bg }} py-10 desk:py-20{% if class %} {{ class }}{% endif %}">
  <div class="mx-auto w-full {{ container_cls }} px-4">
    <div class="space-y-8 desk:space-y-10">
      {% if eyebrow or title or description %}
        <div class="mx-auto flex max-w-3xl flex-col gap-3 text-center">
          {% if eyebrow %}
            <p class="text-xs font-medium uppercase tracking-[0.24em] text-content-muted">
              {{ eyebrow }}
            </p>
          {% endif %}
          {% if title %}
            <h2 class="text-3xl font-semibold tracking-tight text-content desk:text-4xl">
              {{ title }}
            </h2>
          {% endif %}
          {% if description %}
            <p class="text-base leading-7 text-content-muted desk:text-lg">
              {{ description }}
            </p>
          {% endif %}
        </div>
      {% endif %}

      <div
        class="varapress-logo-cloud-marquee overflow-hidden rounded-lg border border-base-400 bg-base-200 py-4"
        style="--varapress-logo-cloud-marquee-duration: {{ duration }}"
      >
        <div class="varapress-logo-cloud-marquee-track flex w-max gap-3 px-3">
          <div class="flex shrink-0 gap-3">
            {% if props.logo_1_name %}
              {{ logo_item(props.logo_1_name, props.logo_1_src, props.logo_1_alt, props.logo_1_href) }}
            {% endif %}
            {% if props.logo_2_name %}
              {{ logo_item(props.logo_2_name, props.logo_2_src, props.logo_2_alt, props.logo_2_href) }}
            {% endif %}
            {% if props.logo_3_name %}
              {{ logo_item(props.logo_3_name, props.logo_3_src, props.logo_3_alt, props.logo_3_href) }}
            {% endif %}
            {% if props.logo_4_name %}
              {{ logo_item(props.logo_4_name, props.logo_4_src, props.logo_4_alt, props.logo_4_href) }}
            {% endif %}
            {% if props.logo_5_name %}
              {{ logo_item(props.logo_5_name, props.logo_5_src, props.logo_5_alt, props.logo_5_href) }}
            {% endif %}
            {% if props.logo_6_name %}
              {{ logo_item(props.logo_6_name, props.logo_6_src, props.logo_6_alt, props.logo_6_href) }}
            {% endif %}
            {% if props.logo_7_name %}
              {{ logo_item(props.logo_7_name, props.logo_7_src, props.logo_7_alt, props.logo_7_href) }}
            {% endif %}
            {% if props.logo_8_name %}
              {{ logo_item(props.logo_8_name, props.logo_8_src, props.logo_8_alt, props.logo_8_href) }}
            {% endif %}
          </div>
          <div class="flex shrink-0 gap-3" aria-hidden="true">
            {% if props.logo_1_name %}
              {{ duplicate_logo(props.logo_1_name, props.logo_1_src) }}
            {% endif %}
            {% if props.logo_2_name %}
              {{ duplicate_logo(props.logo_2_name, props.logo_2_src) }}
            {% endif %}
            {% if props.logo_3_name %}
              {{ duplicate_logo(props.logo_3_name, props.logo_3_src) }}
            {% endif %}
            {% if props.logo_4_name %}
              {{ duplicate_logo(props.logo_4_name, props.logo_4_src) }}
            {% endif %}
            {% if props.logo_5_name %}
              {{ duplicate_logo(props.logo_5_name, props.logo_5_src) }}
            {% endif %}
            {% if props.logo_6_name %}
              {{ duplicate_logo(props.logo_6_name, props.logo_6_src) }}
            {% endif %}
            {% if props.logo_7_name %}
              {{ duplicate_logo(props.logo_7_name, props.logo_7_src) }}
            {% endif %}
            {% if props.logo_8_name %}
              {{ duplicate_logo(props.logo_8_name, props.logo_8_src) }}
            {% endif %}
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
