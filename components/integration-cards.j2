{% set container = props.container | default:"lg" %}
{% set eyebrow = props.eyebrow %}
{% set title = props.title %}
{% set description = props.description %}
{% set cols = props.columns | default:"3" %}
{% set bg = props.bg | default:"base-100" %}
{% set class = props.class %}

{% if container == "xs" %}
  {% set container_cls = "max-w-md" %}
{% elif container == "sm" %}
  {% set container_cls = "max-w-3xl" %}
{% elif container == "md" %}
  {% set container_cls = "max-w-6xl" %}
{% elif container == "xl" %}
  {% set container_cls = "max-w-[120rem]" %}
{% elif container == "full" %}
  {% set container_cls = "max-w-full" %}
{% else %}
  {% set container_cls = "max-w-7xl" %}
{% endif %}

{% macro integration_card(name, icon_name, description, status, href) %}
  <a
    {% if href %}
      href="{{ href }}"
    {% endif %}
    class="group rounded-lg border border-base-400 bg-base-200 p-4 no-underline transition-colors hover:bg-base-300 desk:p-6"
  >
    <div class="flex items-start justify-between gap-4">
      {% if icon_name %}
        <div class="flex size-10 items-center justify-center rounded-md border border-base-400 bg-base-100">
          {{ icon(icon_name, "size-5 text-content") | safe }}
        </div>
      {% endif %}
      {% if status %}
        <span class="rounded-full border border-base-400 px-2.5 py-1 text-[11px] font-medium uppercase tracking-[0.18em] text-content-muted">
          {{ status }}
        </span>
      {% endif %}
    </div>
    <h3 class="mt-5 font-medium text-content">
      {{ name }}
    </h3>
    {% if description %}
      <p class="mt-2 text-sm leading-6 text-content-muted">
        {{ description }}
      </p>
    {% endif %}
  </a>
{% endmacro %}

<section class="bg-{{ bg }} py-10 desk:py-20{% if class %} {{ class }}{% endif %}">
  <div class="mx-auto w-full {{ container_cls }} px-4">
    <div class="space-y-8 desk:space-y-10">
      {% if eyebrow or title or description %}
        <div class="mx-auto flex max-w-3xl flex-col gap-3 text-center">
          {% if eyebrow %}
            <p class="text-xs font-medium uppercase tracking-[0.24em] text-content-muted">
              {{ eyebrow }}
            </p>
          {% endif %}
          {% if title %}
            <h2 class="text-3xl font-semibold tracking-tight text-content desk:text-4xl">
              {{ title }}
            </h2>
          {% endif %}
          {% if description %}
            <p class="text-base leading-7 text-content-muted desk:text-lg">
              {{ description }}
            </p>
          {% endif %}
        </div>
      {% endif %}
      <div class="grid gap-4 desk:gap-5{% if cols == '2' %} desk:grid-cols-2{% else %} desk:grid-cols-3{% endif %}">
        {% if props.item_1_name %}
          {{ integration_card(props.item_1_name, props.item_1_icon, props.item_1_desc, props.item_1_status, props.item_1_href) }}
        {% endif %}
        {% if props.item_2_name %}
          {{ integration_card(props.item_2_name, props.item_2_icon, props.item_2_desc, props.item_2_status, props.item_2_href) }}
        {% endif %}
        {% if props.item_3_name %}
          {{ integration_card(props.item_3_name, props.item_3_icon, props.item_3_desc, props.item_3_status, props.item_3_href) }}
        {% endif %}
        {% if props.item_4_name %}
          {{ integration_card(props.item_4_name, props.item_4_icon, props.item_4_desc, props.item_4_status, props.item_4_href) }}
        {% endif %}
        {% if props.item_5_name %}
          {{ integration_card(props.item_5_name, props.item_5_icon, props.item_5_desc, props.item_5_status, props.item_5_href) }}
        {% endif %}
        {% if props.item_6_name %}
          {{ integration_card(props.item_6_name, props.item_6_icon, props.item_6_desc, props.item_6_status, props.item_6_href) }}
        {% endif %}
      </div>
    </div>
  </div>
</section>
