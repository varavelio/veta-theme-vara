{% set text = props.text|default:props.content|default:"" %}
{% set level = props.level|default:"2" %}
{% set size = props.size|default:"xl" %}
{% set muted = props.muted|default:"false" %}
{% set base = "font-sans font-semibold text-balance" %}
{%   if muted == "true" %}
{% set color_cls = "text-content-muted" %}
{% else %}
{% set color_cls = "text-content" %}
{% endif %}
{% if size == "3xl" %}
{% set size_cls = "text-4xl desk:text-5xl tracking-tighter" %}
{% elif size == "2xl" %}
{% set size_cls = "text-3xl desk:text-4xl tracking-tighter" %}
{% elif size == "xl" %}
{% set size_cls = "text-2xl desk:text-3xl tracking-tight" %}
{% elif size == "lg" %}
{% set size_cls = "text-xl desk:text-2xl tracking-tight" %}
{% elif size == "md" %}
{% set size_cls = "text-lg desk:text-xl tracking-tight" %}
{% elif size == "sm" %}
{% set size_cls = "text-base desk:text-lg tracking-normal" %}
{% else %}
{% set size_cls = "text-sm desk:text-base tracking-normal" %}
{%   endif %}
{% set all = base + " " + color_cls + " " + size_cls %}
{% if props.class %}
{% set all = all + " " + props.class %}
{% endif %}
{% if level == "1" %}<h1 class="{{ all }}">{{ text }}</h1>{%   elif level == "3" %}<h3 class="{{ all }}">{{ text }}</h3>{%   elif level == "4" %}<h4 class="{{ all }}">{{ text }}</h4>{%   elif level == "5" %}<h5 class="{{ all }}">{{ text }}</h5>{%   elif level == "6" %}<h6 class="{{ all }}">{{ text }}</h6>{% else %}<h2 class="{{ all }}">
    {{ text }}
  </h2>{% endif %}
