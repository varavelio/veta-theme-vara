{% set container = props.container|default:"lg" %}
{% set bg = props.bg|default:"base-100" %}
{% set primary_label = props.primary_label|default:data.site.title|default:data.site_default.title|default:"VaraPress" %}
{% set secondary_label = props.secondary_label|default:"Alternative" %}

{% if container == "xs" %}
  {% set container_cls = "max-w-md" %}
{% elif container == "sm" %}
  {% set container_cls = "max-w-3xl" %}
{% elif container == "md" %}
  {% set container_cls = "max-w-6xl" %}
{% elif container == "xl" %}
  {% set container_cls = "max-w-[120rem]" %}
{% elif container == "full" %}
  {% set container_cls = "max-w-full" %}
{% else %}
  {% set container_cls = "max-w-7xl" %}
{% endif %}

<section class="bg-{{ bg }} py-10 desk:py-20{% if props.class %} {{ props.class }}{% endif %}">
  <div class="mx-auto w-full {{ container_cls }} px-4">
    <div class="space-y-8 desk:space-y-10">
      {% if props.eyebrow or props.title or props.description %}
        <div class="mx-auto flex max-w-3xl flex-col gap-3 text-center">
          {% if props.eyebrow %}
            <p class="text-xs font-medium uppercase tracking-[0.24em] text-content-muted">
              {{ props.eyebrow }}
            </p>
          {% endif %}
          {% if props.title %}
            <h2 class="text-3xl font-semibold tracking-tight text-content desk:text-4xl">
              {{ props.title }}
            </h2>
          {% endif %}
          {% if props.description %}
            <p class="text-base leading-7 text-content-muted desk:text-lg">
              {{ props.description }}
            </p>
          {% endif %}
        </div>
      {% endif %}

      <div class="overflow-x-auto rounded-lg border border-base-400 bg-base-200 p-4 desk:p-6">
        <table class="w-full min-w-[40rem] border-collapse text-left text-sm">
          <thead>
            <tr class="border-b border-base-400 text-content">
              <th class="py-3 pr-4 font-medium">
                Capability
              </th>
              <th class="px-4 py-3 font-medium">
                {{ primary_label }}
              </th>
              <th class="px-4 py-3 font-medium">
                {{ secondary_label }}
              </th>
            </tr>
          </thead>
          <tbody class="divide-y divide-base-400">
            {% if props.row_1_feature %}
              <tr>
                <td class="py-4 pr-4 font-medium text-content">
                  {{ props.row_1_feature }}
                </td>
                <td class="px-4 py-4 text-content-muted">
                  {% if props.row_1_primary == "true" %}
                    {{ icon("check", "size-4 text-content")|safe }}
                  {% elif props.row_1_primary == "false" %}
                    {{ icon("x", "size-4 text-content-muted")|safe }}
                  {% else %}
                    {{ props.row_1_primary }}
                  {% endif %}
                </td>
                <td class="px-4 py-4 text-content-muted">
                  {% if props.row_1_secondary == "true" %}
                    {{ icon("check", "size-4 text-content")|safe }}
                  {% elif props.row_1_secondary == "false" %}
                    {{ icon("x", "size-4 text-content-muted")|safe }}
                  {% else %}
                    {{ props.row_1_secondary }}
                  {% endif %}
                </td>
              </tr>
            {% endif %}
