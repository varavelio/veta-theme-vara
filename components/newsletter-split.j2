{% import "../templates/veta/macros/button.j2" button %}

{% set container = props.container | default:"lg" %}
{% set eyebrow = props.eyebrow %}
{% set title = props.title %}
{% set description = props.description %}
{% set form_action = props.form_action | default:"" %}
{% set method = props.method | default:"post" %}
{% set email_placeholder = props.email_placeholder | default:"you@example.com" %}
{% set button_text = props.button_text | default:"Subscribe" %}
{% set note = props.note %}
{% set success_message = props.success_message | default:"You are on the list." %}
{% set bg = props.bg | default:"base-100" %}
{% set class = props.class %}

{% if container == "xs" %}
  {% set container_cls = "max-w-md" %}
{% elif container == "sm" %}
  {% set container_cls = "max-w-3xl" %}
{% elif container == "md" %}
  {% set container_cls = "max-w-6xl" %}
{% elif container == "xl" %}
  {% set container_cls = "max-w-[120rem]" %}
{% elif container == "full" %}
  {% set container_cls = "max-w-full" %}
{% else %}
  {% set container_cls = "max-w-7xl" %}
{% endif %}

<section class="bg-{{ bg }} py-10 desk:py-20{% if class %} {{ class }}{% endif %}">
  <div class="mx-auto w-full {{ container_cls }} px-4">
    <div class="grid gap-6 rounded-lg border border-base-400 bg-base-200 p-4 desk:grid-cols-[1fr_0.9fr] desk:items-center desk:p-6">
      <div>
        <div class="flex size-10 items-center justify-center rounded-md border border-base-400 bg-base-100">
          {{ icon("mail", "size-5 text-content") | safe }}
        </div>
        <div class="mt-5">
          {% if eyebrow or title or description %}
            <div class="flex max-w-3xl flex-col gap-3 text-left">
              {% if eyebrow %}
                <p class="text-xs font-medium uppercase tracking-[0.24em] text-content-muted">
                  {{ eyebrow }}
                </p>
              {% endif %}
              {% if title %}
                <h2 class="text-3xl font-semibold tracking-tight text-content desk:text-4xl">
                  {{ title }}
                </h2>
              {% endif %}
              {% if description %}
                <p class="text-base leading-7 text-content-muted desk:text-lg">
                  {{ description }}
                </p>
              {% endif %}
            </div>
          {% endif %}
        </div>
      </div>
      <form
        {% if form_action %}
          action="{{ form_action }}"
        {% endif %}
        method="{{ method }}"
        class="rounded-md border border-base-400 bg-base-100 p-4"
        x-data="{ submitted: false }"
        {% if not form_action %}
          x-on:submit.prevent="submitted = true"
        {% endif %}
      >
        <label class="sr-only" for="newsletter-email">Email</label>
        <div class="flex flex-col gap-3 desk:flex-row">
          <input
            id="newsletter-email"
            name="email"
            type="email"
            required
            placeholder="{{ email_placeholder }}"
            class="h-12 min-w-0 flex-1 rounded-md border border-base-400 bg-base-100 px-3 text-sm text-content outline-content placeholder:text-content-muted focus-visible:outline-2 focus-visible:outline-offset-2"
          />
          {{ button(button_text, "", "", "", "", "lg", "md", "solid", "neutral", "true", "false", "submit", "desk:w-auto") }}
        </div>
        {% if note %}
          <p class="mt-3 text-xs leading-5 text-content-muted">
            {{ note }}
          </p>
        {% endif %}
        <p class="mt-3 text-sm font-medium text-content" x-show="submitted" x-cloak>
          {{ success_message }}
        </p>
      </form>
    </div>
  </div>
</section>
